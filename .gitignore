# Stage outputs are tracked — downstream stages read from them
# (previous rule blocking **/stages/*/output/* removed 2026-06-12)

# Claude Code local settings (exclude local state, allow committed team config)
.claude/
!.claude/hooks/
!.claude/hooks/**
!.claude/settings.json
!.claude/skills/
!.claude/skills/**
!.claude/rules/
!.claude/rules/**

# IDE project files
.idea/

# Node dependencies
node_modules/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor files
*.swp
*.swo
*~
.vscode/settings.json

# Environment files
.env
.env.local
.env.*
*.env

# API keys and secrets
.secrets
secrets.*
*.secrets
secrets-*
*.key
*.pem
api-keys.*
credentials.*

# GBrain (config lives in ~/.gbrain, not the repo, but belt-and-suspenders)
.gbrain/
gbrain.config.*
.gbrain-source

# Graphify output (gitignored per workspace too, belt-and-suspenders)
graphify-out/

# Cloned reference repos (local only)
*-ref/
.gstack/

# Always track gstack and graphify source (never gitignore these)
!skills/gstack/
!skills/gstack/**
!scripts/refresh_graph.py
!scripts/query_graph.py
!scripts/verify_graph.py

.vercel

# Stray Python packages (created in wrong location)
UsersraymoAppDataLocal*/
UsersRaymoAppDataLocal*/
